# Copy this file to .env and fill in your values.
# The game works without these — players can enter their API key in the browser UI.

# TAMU AI Chat API key (optional — players can also set it in the browser)
# TAMUS_AI_CHAT_API_KEY=your-key-here
# Flask session secret key — change this to a random string in production
FLASK_SECRET_KEY=change-me-to-something-random

# Scene images (Pollinations) — optional tuning for speed vs. quality
# DISABLE_SCENE_IMAGES=1
# SCENE_IMAGES_OFFLINE_ONLY=1    # never call Pollinations; only static/scene_images/*.jpg (see pregenerate script)
# SCENE_IMAGE_SAVE_FETCHED=1     # after a successful upstream fetch, write JPEG to static/scene_images/ for next time
# SCENE_IMAGE_MODEL=turbo        # default; use flux for slower, richer images
# SCENE_IMAGE_WIDTH=512
# SCENE_IMAGE_HEIGHT=320
# SCENE_IMAGE_UPSTREAM_TIMEOUT=120
# SCENE_IMAGE_CACHE_MAX=48
# Pre-built images in static/scene_images/ are served instantly (see scripts/pregenerate_scene_images.py).
# Theme WAVs in static/audio_themes/ load instantly in the browser (see scripts/pregenerate_audio_themes.py): ambient_*.wav, music_*.wav, ui_*.wav.
