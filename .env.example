# Copy this file to .env and fill in your values.
# The game works without these — players can enter their API key in the browser UI.

# TAMU AI Chat API key (optional — players can also set it in the browser)
TAMUS_AI_CHAT_API_KEY=

# Flask session secret key — change this to a random string in production
FLASK_SECRET_KEY=change-me-to-something-random
